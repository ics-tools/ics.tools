{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://ics.tools/data/schema/public-holidays.schema.json",
    "title": "ics.tools Public holiday schema",
    "type": "object",
    "required": [
        "holidays"
    ],
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string",
            "format": "uri-reference"
        },
        "holidays": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "startDate",
                    "endDate",
                    "md5",
                    "created",
                    "modified",
                    "sequence",
                    "states"
                ],
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid",
                        "description": "Unique holiday identifier"
                    },
                    "name": {
                        "type": "string",
                        "description": "Holiday display name"
                    },
                    "startDate": {
                        "type": "string",
                        "format": "date",
                        "description": "Start date in YYYY-MM-DD format"
                    },
                    "endDate": {
                        "type": "string",
                        "format": "date",
                        "description": "End date in YYYY-MM-DD format"
                    },
                    "md5": {
                        "type": "string",
                        "pattern": "^[a-fA-F0-9]{32}$",
                        "description": "MD5 hash of the holiday data"
                    },
                    "created": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Creation timestamp (ISO 8601)"
                    },
                    "modified": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Last modification timestamp (ISO 8601)"
                    },
                    "sequence": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Version counter for changes"
                    },
                    "states": {
                        "description": "Federal states in which the holiday is valid.",
                        "type": "array",
                        "minItems": 1,
                        "uniqueItems": true,
                        "items": {
                            "type": "string",
                            "description": "Two-letter German federal state code.",
                            "enum": [
                                "BW",
                                "BY",
                                "BE",
                                "BB",
                                "HB",
                                "HH",
                                "HE",
                                "MV",
                                "NI",
                                "NW",
                                "RP",
                                "SL",
                                "SN",
                                "ST",
                                "SH",
                                "TH"
                            ]
                        }
                    }
                }
            }
        }
    }
}