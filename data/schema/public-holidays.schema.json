{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://ics.tools/data/schema/public-holidays.schema.json",
    "title": "ics.tools Public holiday schema",
    "type": "object",
    "required": [
        "metadata",
        "holidays"
    ],
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string",
            "format": "uri-reference"
        },
        "metadata": {
            "type": "object",
            "required": [
                "state",
                "code"
            ],
            "additionalProperties": false,
            "properties": {
                "state": {
                    "type": "string",
                    "description": "Vollständiger Name des Bundeslandes (z.B. Bayern)"
                },
                "code": {
                    "type": "string",
                    "enum": [
                        "BW",
                        "BY",
                        "BE",
                        "BB",
                        "HB",
                        "HH",
                        "HE",
                        "MV",
                        "NI",
                        "NW",
                        "RP",
                        "SL",
                        "SN",
                        "ST",
                        "SH",
                        "TH"
                    ],
                    "description": "Zweistelliges ISO-Kürzel"
                }
            }
        },
        "holidays": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "date",
                    "md5",
                    "created",
                    "modified",
                    "sequence"
                ],
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid",
                        "description": "Eindeutige ID des Feiertags"
                    },
                    "name": {
                        "type": "string",
                        "description": "Bezeichnung des Feiertags"
                    },
                    "date": {
                        "type": "string",
                        "format": "date",
                        "description": "Datum im Format YYYY-MM-DD"
                    },
                    "md5": {
                        "type": "string",
                        "pattern": "^[a-fA-F0-9]{32}$",
                        "description": "MD5 Hash der Feiertagsdaten"
                    },
                    "created": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Erstellungszeitpunkt (ISO 8601)"
                    },
                    "modified": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Letzter Änderungszeitpunkt (ISO 8601)"
                    },
                    "sequence": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Versionszähler für Änderungen"
                    }
                }
            }
        }
    }
}